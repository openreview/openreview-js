# Image that runs the openreview-js mocha suites.
# @openreview/meta-extraction launches puppeteer's bundled Chromium with no
# executablePath, so the image needs Chromium's runtime shared libraries.
# (We do NOT set PUPPETEER_SKIP_DOWNLOAD here — puppeteer must fetch Chromium.)
FROM node:22-bookworm

RUN apt-get update && apt-get install -y \
    rsync \
    ca-certificates fonts-liberation \
    libnss3 libnspr4 \
    libatk1.0-0 libatk-bridge2.0-0 libatspi2.0-0 \
    libcups2 libdrm2 libgbm1 libasound2 \
    libpango-1.0-0 libpangocairo-1.0-0 libcairo2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
    libxshmfence1 libx11-xcb1 libxcb1 libxext6 libxi6 libxtst6 \
    libgtk-3-0 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
